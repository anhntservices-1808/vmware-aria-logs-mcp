# --- MCP transport (HTTP wrap) ---
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8770

# --- VMware Aria Operations for Logs (Log Insight) ---
LI_BASE_URL=https://loginsight.example.com
LI_USERNAME=admin
LI_PASSWORD=
LI_PROVIDER=Local
# TLS verify left at default (false). Set true when CA trust is ready.
LI_VERIFY_TLS=false
LI_TIMEOUT_SEC=30

# --- VMware Aria Operations (vROps) correlation (optional) ---
# Leave VROPS_BASE_URL empty to disable vROps tools.
VROPS_BASE_URL=
VROPS_USERNAME=admin
VROPS_PASSWORD=
VROPS_AUTH_SOURCE=local
VROPS_VERIFY_TLS=false
VROPS_TIMEOUT_SEC=30
